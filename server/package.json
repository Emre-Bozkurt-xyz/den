{
  "name": "@den/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx dist-test-glob 2>/dev/null || echo \"(no server tests yet)\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@den/shared": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "postgres": "^3.4.5",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.30.2",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2"
  }
}
