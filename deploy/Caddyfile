# Den — Caddy reverse proxy. Plain HTTP only: TLS is terminated upstream by
# the reverse proxy on the VPS (frp tunnels decrypted HTTP from there to this
# host's :80) — Caddy here must NOT attempt its own automatic HTTPS/ACME or
# it'll redirect the already-plaintext tunneled request back to https with
# nothing on this end to receive it. The explicit `http://` scheme on the
# site address is what opts this block out of Caddy's automatic HTTPS.
# App (static PWA) + API + WSS are all same-origin behind this one host, which
# is what keeps the session cookie and socket.io simple (BACKBONE §3, §8).

http://den.ems-place.com {
	encode gzip zstd

	# API + health → Fastify.
	handle /api/* {
		reverse_proxy api:3000
	}
	handle /health {
		reverse_proxy api:3000
	}

	# socket.io (WSS upgrade). Caddy passes Upgrade/Connection headers through
	# reverse_proxy automatically. Keep the read timeout above the 25s WS ping
	# so proxies don't kill idle sockets (BACKBONE §8).
	handle /socket.io/* {
		reverse_proxy api:3000
	}

	# Everything else = the built PWA (static files from the app build).
	#
	# ⚠️ Cache-Control here is load-bearing, not tidiness. `file_server` sets
	# only ETag/Last-Modified; with no Cache-Control at all, browsers fall
	# back to *heuristic* freshness (~10% of the age since Last-Modified).
	# Since dist/ is baked into the image at build time, Last-Modified is the
	# image build date — so a few days after a deploy, index.html was being
	# served straight from the HTTP cache with no revalidation, still pointing
	# at the previous hashed bundle. That's what used to make a deploy invisible
	# on installed PWAs until the user wiped all website data.
	handle {
		root * /srv/app

		# Vite's content-hashed output: the filename changes whenever the bytes
		# do, so these can be cached forever and never revalidated.
		@immutable path /assets/*
		header @immutable Cache-Control "public, max-age=31536000, immutable"

		# Everything else — index.html, sw.js, the manifest, icons — has a
		# stable URL with changing content, so it must revalidate every time.
		# The cost is a conditional request answered with 304, not a re-download.
		@revalidate {
			not path /assets/*
		}
		header @revalidate Cache-Control "no-cache"

		try_files {path} /index.html
		file_server
	}

	# Long-lived sockets: don't cut the connection under the ping interval.
	# (Caddy default proxy has no hard read timeout; this documents intent.)
	log {
		output stdout
		format console
	}
}
