# ─── Den environment (copy to .env; never commit .env) ──────────────────────

# Core
NODE_ENV=development
# Public origin of the app (locked production domain — see BACKBONE §5 rpID trap)
PUBLIC_ORIGIN=https://den.ems-place.com
# API listen
API_HOST=0.0.0.0
API_PORT=3000

# Postgres
# Host port the compose postgres publishes on 127.0.0.1 (change if 5432 is taken
# locally). DATABASE_URL below must match it for host-side tooling.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://den:den@localhost:5432/den
POSTGRES_USER=den
POSTGRES_PASSWORD=den
POSTGRES_DB=den

# Sessions
# 32+ byte random string; used to sign the session cookie
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_DOMAIN=den.ems-place.com

# Web Push (VAPID) — generate with: npm run vapid:gen
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ems-place.com

# Object storage (media) — Stage 3.
# Local dev: leave these defaults — they point at the docker-compose MinIO
# service (S3-compatible stand-in for R2, `deploy/docker-compose.yml`).
# Prod: point R2_ENDPOINT at the real Cloudflare R2 account endpoint
# (https://<account_id>.r2.cloudflarestorage.com), set real credentials, and
# leave R2_PUBLIC_ENDPOINT unset (R2's endpoint is already browser-reachable).
R2_ENDPOINT=http://localhost:9000
R2_PUBLIC_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=den-dev
R2_SECRET_ACCESS_KEY=den-dev-secret
R2_BUCKET=den-media
R2_FORCE_PATH_STYLE=true
