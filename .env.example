# ─── Den environment (copy to .env; never commit .env) ──────────────────────

# Core
NODE_ENV=development
# Public origin of the app (locked production domain — see BACKBONE §5 rpID trap)
PUBLIC_ORIGIN=https://den.ems-place.com
# API listen
API_HOST=0.0.0.0
API_PORT=3000

# Postgres
DATABASE_URL=postgres://den:den@localhost:5432/den
POSTGRES_USER=den
POSTGRES_PASSWORD=den
POSTGRES_DB=den

# Sessions
# 32+ byte random string; used to sign the session cookie
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_DOMAIN=den.ems-place.com

# Web Push (VAPID) — generate with: npm run vapid:gen
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ems-place.com

# Cloudflare R2 (media) — Stage 3; leave blank for Stage 0
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=den-media
R2_ENDPOINT=
